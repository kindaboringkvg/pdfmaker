{
  "expo": {
    "name": "PrivacyScan",
    "slug": "privacyscan",
    "scheme": "privacyscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.privacyscan.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020a2f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.privacyscan.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PrivacyScan to access your camera to scan documents."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow PrivacyScan to save scanned documents to your photo library."
        }
      ],
      "expo-sharing",
      "expo-mail-composer",
      "expo-status-bar"
    ]
  }
}
